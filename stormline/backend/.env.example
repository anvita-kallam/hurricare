# Local Development (DuckDB - default)
# No env vars needed, uses in-memory DuckDB

# Production (Databricks SQL Warehouse)
# Uncomment these and fill in your Databricks credentials:
# DATABRICKS_SERVER_HOSTNAME=adb-1234567890.azuredatabricks.net
# DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/abc123def456
# DATABRICKS_PAT=dapi1234567890abcdef

# How to get these:
# 1. DATABRICKS_SERVER_HOSTNAME: https://docs.databricks.com/dev-tools/auth.html
# 2. DATABRICKS_HTTP_PATH: From your SQL Warehouse details in Databricks workspace
# 3. DATABRICKS_PAT: Generate in Databricks > Settings > User Settings > Access Tokens

# Voice personal accounts (Gemini + ElevenLabs)
# GEMINI_API_KEY=your_key_from_aistudio.google.com
# ELEVENLABS_API_KEY=your_key_from_elevenlabs.io
